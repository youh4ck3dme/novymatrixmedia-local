# ============================================================
# .gitignore – Nový Matrix Media (koreňový adresár)
# ============================================================

# --- Citlivé súbory – NIKDY do Git! ---
.env
.env.local
.env.production
.env.vercel
.env.*.local
wp-config.php
wp-config-production.php

# --- WordPress core (aktualizuje sa cez FTP, nie Git) ---
wp-admin/
wp-includes/
wp-activate.php
wp-blog-header.php
wp-comments-post.php
wp-cron.php
wp-links-opml.php
wp-load.php
wp-login.php
wp-mail.php
wp-settings.php
wp-signup.php
wp-trackback.php
xmlrpc.php
/index.php
/readme.html
/license.txt

# --- Tretie-stranné pluginy a témy (nie vlastné) ---
wp-content/plugins/
wp-content/themes/
# Výnimky pre vlastné pluginy/témy (odkomentuj ak existujú):
# !wp-content/plugins/nmm-vlastny-plugin/
# !wp-content/themes/nmm-tema/
!wp-content/plugins/
wp-content/plugins/*
!wp-content/plugins/nmm-telegram-bridge/
!wp-content/plugins/nmm-telegram-bridge/**
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/bluetone/
wp-content/themes/bluetone/*
!wp-content/themes/bluetone/inc/
wp-content/themes/bluetone/inc/*
!wp-content/themes/bluetone/inc/editorial-fields.php

# --- WordPress generované súbory ---
wp-content/cache/
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/updraft/
wp-content/wflogs/
wp-content/uploads/
wp-content/languages/
wp-content/mu-plugins/
!wp-content/mu-plugins/
wp-content/mu-plugins/*
!wp-content/mu-plugins/nmm-revalidate.php
!wp-content/mu-plugins/nmm-bluetone-unlocker.php
!wp-content/mu-plugins/nmm-firewall.php
!wp-content/mu-plugins/nmm-editorial-fields.php
!wp-content/mu-plugins/nmm-headless-routing.php
!wp-content/mu-plugins/nmm-comments-moderation.php
!wp-content/mu-plugins/nmm-excerpt-ellipsis-fix.php
!wp-content/mu-plugins/nmm-vercel-billing-notice.php
wp-content/settings/
wp-content/advanced-cache.php
wp-content/index.php
wp-content/.DS_Store

# --- Next.js / Node ---
nmm-pwa/.next/
nmm-pwa/node_modules/
node_modules/
package-lock.json
nmm-pwa/package-lock.json

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- Backup a deploy artefakty ---
*.sql
*.sql.gz
*.tar.gz
nmm_deploy_bundle.tar.gz
novymatrixmedia_export.sql.gz
nmm_*.py
nmm-pass-reset.php
__pycache__/

# --- macOS ---
.DS_Store
__MACOSX/

# --- IDE a workspace ---
.vscode/
*.code-workspace

# --- Logy ---
*.log
debug.log
.vercel
