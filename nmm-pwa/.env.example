# ============================================================
# Next.js PWA – ŠABLÓNA premenných prostredia (bezpečná na Git)
# Skopíruj do .env.local a vyplň skutočné hodnoty
# ============================================================

# WordPress CMS / API vrstva
NEXT_PUBLIC_WP_URL=https://info.novymatrixmedia.sk
NEXT_PUBLIC_API_URL=https://info.novymatrixmedia.sk/wp-json/wp/v2

# Verejná frontend doména
NEXT_PUBLIC_SITE_URL=https://novymatrixmedia.sk

# GraphQL endpoint (WPGraphQL plugin)
NEXT_PUBLIC_GRAPHQL_URL=https://info.novymatrixmedia.sk/graphql

# On-demand revalidation – musí sedieť s NMM_REVALIDATE_SECRET vo WordPresse
REVALIDATE_SECRET=change_me_local_dev_secret

# Voliteľné: WordPress Application Password pre proxy submit komentárov
# WP_COMMENT_APP_USER=
# WP_COMMENT_APP_PASSWORD=
